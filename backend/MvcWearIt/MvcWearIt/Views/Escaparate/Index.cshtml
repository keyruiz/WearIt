@using MvcWearIt.Models @* Asegúrate de que apunte a tus modelos *@
@{
    ViewData["Title"] = "Escaparate";
    var listaCategorias = ViewData["ListaCategorias"] as List<Categoria>;
    var juegoId = ViewData["JuegoIdSeleccionado"];
    var categoriaIdSeleccionada = ViewData["CategoriaIdSeleccionada"];
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Escaparate de la Tienda</h2>

    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <table class="table table-bordered text-center bg-light">
                <tbody>
                    <tr>
                        <td>
                            <a href="/Escaparate?juegoId=@juegoId" class="btn btn-sm @(categoriaIdSeleccionada == null ? "btn-dark" : "btn-outline-dark")">
                                Ver Todo el Escaparate
                            </a>
                        </td>
                        @if (listaCategorias != null)
                        {
                            foreach (var cat in listaCategorias)
                            {
                                <td>
                                    <a href="/Escaparate?juegoId=@juegoId&id=@cat.Id"
                                       class="btn btn-sm @(categoriaIdSeleccionada?.ToString() == cat.Id.ToString() ? "btn-dark" : "btn-outline-dark")">
                                        @cat.Descripcion
                                    </a>
                                </td>
                            }
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="contenedor-productos" class="row"></div>
</div>

<input type="hidden" id="hdnJuegoId" value="@juegoId" />
<input type="hidden" id="hdnCategoriaId" value="@categoriaIdSeleccionada" />

<template id="plantilla-producto">
    <div class="col-md-3 mb-4">
        <div class="card h-100 shadow-sm">
            <img class="card-img-top producto-imagen" src="" alt="Imagen producto" style="height:200px; object-fit:contain; background:#f8f9fa;" />
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="producto-descripcion text-dark"></h5>
                    <span class="badge bg-secondary mb-2 producto-categoria"></span>
                </div>
                <div>
                    <p class="producto-precio text-success fs-5 fw-bold m-0"></p>
                    <button class="btn btn-primary w-100 boton-carrito">Añadir al carrito</button>
                </div>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/js/escaparate.js"></script>
}
