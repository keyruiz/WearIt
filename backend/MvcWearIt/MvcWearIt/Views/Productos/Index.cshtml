@model IEnumerable<MvcWearIt.Models.Producto>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Productos";
}

<h1>Productos</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="juegoId" class="form-select" asp-items="ViewBag.Juegos">
            <option value="">Todos los juegos</option>
        </select>
    </div>
    <div class="col-auto">
        <input type="text" name="search" class="form-control" placeholder="Buscar por nombre..." value="@ViewBag.Search" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Texto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Precio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Imagen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Categoria)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Juego)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Descripcion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Texto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Precio)
            </td>
            <td>
                @{
                    var esUrl = item.Imagen != null && (item.Imagen.StartsWith("http://") || item.Imagen.StartsWith("https://"));
                }
                @if (esUrl)
                {
                    <img src="@item.Imagen" height="40" />
                }
                else
                {
                    var nombreImagen = item.Imagen ?? "imagen-no-disponible.jpg";
                    <img src="~/imagenes/@nombreImagen" height="40" asp-append-version="true" />
                }
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Categoria.Descripcion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Juego.Nombre)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
