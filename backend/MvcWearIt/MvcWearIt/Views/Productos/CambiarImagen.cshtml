@model MvcWearIt.Models.Producto

@{
    ViewData["Title"] = "Cambiar imagen";
}

<h1>Cambiar imagen</h1>

<div>
    <h4>Producto</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Descripcion)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Descripcion)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Precio)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Precio)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Categoria)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Categoria.Descripcion)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Imagen)</dt>
        <dd class="col-sm-10">
            <div>
                <div>
                    @{
                        var nombreImagen = "imagen-no-disponible.jpg";
                        if (Model.Imagen != null)
                        {
                            nombreImagen = Model.Imagen;
                        }
                    }
                    <img src="~/imagenes/@nombreImagen" height="250" width="250"
                         asp-append-version="true" />
                </div>
                <br />
                <div>
                    <form enctype="multipart/form-data" asp-action="CambiarImagen">
                        <div class="form-group" hidden>
                            <label asp-for="Id" class="control-label"></label>
                            <input asp-for="Id" class="form-control" />
                        </div>
                        <div class="form-group">
                            <input type="file" asp-for="Imagen" class="form-control-file">
                        </div>
                        <br />
                        <div class="form-group">
                            <input type="submit" value="Actualizar imagen" class="btn btn-sm btn-primary rounded-0" />
                        </div>
                    </form>
                </div>
            </div>
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Index">Volver</a>
</div>
