@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Usuarios";
}

<h1>Usuarios</h1>

<table class="table">
    <thead>
        <tr>
            <th>Email</th>
            <th>Nombre de Usuario</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td>@item.UserName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Ver Datos y Compras</a>
                </td>
            </tr>
        }
    </tbody>
</table>
