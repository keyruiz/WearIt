@model Microsoft.AspNetCore.Identity.IdentityUser

@{
    ViewData["Title"] = "Detalles de Usuario";
    var esAdmin = (bool)ViewBag.EsAdmin;
    var pedidos = (List<MvcWearIt.Models.Pedido>)ViewBag.Pedidos;
}

<h1>Detalles de Usuario</h1>

<div>
    <h4>@Model.Email</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>
        <dt class="col-sm-2">Nombre de Usuario</dt>
        <dd class="col-sm-10">@Model.UserName</dd>
        <dt class="col-sm-2">Rol</dt>
        <dd class="col-sm-10">
            @if (esAdmin)
            {
                <span class="badge bg-danger">Administrador</span>
            }
            else
            {
                <span class="badge bg-secondary">Usuario</span>
            }
        </dd>
    </dl>
</div>

<h3 class="mt-4">Historial de Pedidos</h3>

@if (esAdmin)
{
    <p>Los administradores no pueden realizar compras.</p>
}
else if (pedidos.Count == 0)
{
    <p>Este usuario no ha realizado pedidos.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nº Pedido</th>
                <th>Fecha</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in pedidos)
            {
                var total = pedido.Detalles.Sum(d => d.Cantidad * d.Precio);
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="fw-bold">@total.ToString("C")</td>
                    <td>
                        <a asp-controller="Pedidos" asp-action="Details" asp-route-id="@pedido.Id">Ver Detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="ChangeRole" asp-route-id="@Model.Id" class="btn btn-warning">Cambiar Rol</a>
</div>

<div>
    <a asp-action="Index">Volver a la lista</a>
</div>
