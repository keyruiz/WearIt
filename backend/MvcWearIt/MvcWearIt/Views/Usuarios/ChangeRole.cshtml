@{
    ViewData["Title"] = "Cambiar Rol";
    var esAdmin = (bool)ViewBag.EsAdmin;
}

<h1>Cambiar Rol</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@ViewBag.UserEmail</dd>
            <dt class="col-sm-4">Usuario</dt>
            <dd class="col-sm-8">@ViewBag.UserName</dd>
            <dt class="col-sm-4">Rol actual</dt>
            <dd class="col-sm-8">
                @if (esAdmin)
                {
                    <span class="badge bg-danger">Administrador</span>
                }
                else
                {
                    <span class="badge bg-secondary">Usuario</span>
                }
            </dd>
        </dl>

        <form asp-action="ChangeRole" method="post">
            <input type="hidden" name="id" value="@ViewBag.UserId" />
            <div class="mb-3">
                <label class="form-label">Nuevo rol</label>
                <select name="nuevoRol" class="form-select">
                    <option value="Administrador" selected="@(esAdmin ? false : true)">Administrador</option>
                    <option value="Usuario" selected="@(esAdmin ? true : false)">Usuario</option>
                </select>
            </div>
            <button type="submit" class="btn btn-warning">Cambiar Rol</button>
            <a asp-action="Details" asp-route-id="@ViewBag.UserId" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Volver a la lista</a>
</div>
