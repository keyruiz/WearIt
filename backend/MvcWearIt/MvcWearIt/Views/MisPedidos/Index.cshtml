@model IEnumerable<MvcWearIt.Models.Pedido>

@{
    ViewData["Title"] = "Mis Pedidos";
}

<h1>Mis Pedidos</h1>

@if (!Model.Any())
{
    <p class="text-muted">No has realizado ningún pedido todavía.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nº Pedido</th>
                <th>Fecha</th>
                <th>Productos</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                var total = pedido.Detalles.Sum(d => d.Cantidad * d.Precio);
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <ul class="list-unstyled mb-0">
                            @foreach (var detalle in pedido.Detalles)
                            {
                                <li>@detalle.Producto?.Descripcion (@detalle.Cantidad x @detalle.Precio.ToString("C"))</li>
                            }
                        </ul>
                    </td>
                    <td class="fw-bold">@total.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div>
    <a href="/Juegos/Index" class="btn btn-outline-dark">Volver a la tienda</a>
</div>
