@{
    ViewData["Title"] = "Inicio - MvcWearIt";
}

<div class="container text-center mt-5">
    <h1 class="display-4 mb-4">Selecciona tu Videojuego</h1>

    <div id="contenedor-juegos" class="row justify-content-center"></div>
</div>

<template id="plantilla-juego">
    <div class="col-md-4 mb-4">
        <div class="card tarjeta-juego h-100 shadow-sm" style="cursor: pointer; border: 2px solid #333; transition: transform 0.2s; background-size: cover; background-position: center; min-height: 200px;">
            <div class="card-body d-flex align-items-end justify-content-center" style="min-height: 200px; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 100%); border-radius: calc(0.375rem - 1px);">
                <h3 class="nombre-juego text-white m-0 fw-bold" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8);">Nombre del Juego</h3>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/js/inicio.js"></script>
}