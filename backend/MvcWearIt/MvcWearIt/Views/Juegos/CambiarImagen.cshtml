@model MvcWearIt.Models.Juego

@{
    ViewData["Title"] = "Cambiar imagen de portada";
}

<h1>Cambiar imagen de portada</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div>
    <h4>@Model.Nombre</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Nombre)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Nombre)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.ImagenPortada)</dt>
        <dd class="col-sm-10">
            <div>
                <div>
                    @{
                        var nombreImagen = "imagen-no-disponible.jpg";
                        if (Model.ImagenPortada != null)
                        {
                            nombreImagen = Model.ImagenPortada;
                        }
                    }
                    <img src="~/imagenes/@nombreImagen" height="250" width="250"
                         asp-append-version="true" />
                </div>
                <br />
                <div>
                    <form enctype="multipart/form-data" asp-action="CambiarImagen">
                        <div class="form-group" hidden>
                            <label asp-for="Id" class="control-label"></label>
                            <input asp-for="Id" class="form-control" />
                        </div>
                        <div class="form-group">
                            <input type="file" name="imagen" class="form-control-file">
                        </div>
                        <br />
                        <div class="form-group">
                            <input type="submit" value="Actualizar imagen" class="btn btn-sm btn-primary rounded-0" />
                        </div>
                    </form>
                </div>
            </div>
        </dd>
    </dl>
</div>

<div>
    <a asp-action="AdminIndex">Volver</a>
</div>
