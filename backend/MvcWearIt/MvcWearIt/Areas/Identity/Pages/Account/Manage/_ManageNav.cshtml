@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<style>
    .nav-pills .nav-link {
        color: #000000 !important; /* El color negro */
        font-weight: 500;
        transition: background-color 0.2s, color 0.2s;
    }

        /* Controla cómo se ve cuando pasas el ratón por encima (Hover) */
        .nav-pills .nav-link:hover {
            background-color: #f0f0f0 !important; /* Un gris muy sutil de fondo */
            color: #000000 !important;
        }

        /* Respeta el botón que está seleccionado actualmente (el azul de Profile) */
        .nav-pills .nav-link.active {
            background-color: #0d6efd !important; /* El azul oficial de Bootstrap */
            color: #ffffff !important; /* Texto blanco solo para la opción activa */
        }
</style>

<ul class="nav nav-pills flex-column">
    <li class="nav-item"><a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">Profile</a></li>
    <li class="nav-item"><a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">Email</a></li>
    <li class="nav-item"><a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">Password</a></li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item"><a id="external-login" class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">External logins</a></li>
    }
    <li class="nav-item"><a class="nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">Two-factor authentication</a></li>
    <li class="nav-item"><a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">Personal data</a></li>
    <li class="nav-item"><a class="nav-link" id="mis-pedidos" asp-controller="MisPedidos" asp-action="Index">Mis Pedidos</a></li>
</ul>
